rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /clientes/{clienteId} {
      // Cualquier usuario autenticado puede leer el listado completo de clientes.
      allow read: if request.auth != null;

      // Al crear, se valida tipo y rango de los campos clave, y que el
      // documento quede asociado al usuario autenticado que lo crea.
      allow create: if request.auth != null
                    && request.resource.data.nombre is string
                    && request.resource.data.apellido is string
                    && request.resource.data.edad is int
                    && request.resource.data.edad >= 0
                    && request.resource.data.edad <= 120
                    && request.resource.data.uid == request.auth.uid;

      // Solo el usuario que creó el registro puede modificarlo o borrarlo.
      allow update, delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }
  }
}
